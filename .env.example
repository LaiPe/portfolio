# Copier en .env.development (dev local) / configurer sur l'hébergeur en prod.
# Requis par la Gatsby Function src/api/contact.ts (formulaire de contact via Resend).

RESEND_API_KEY=
# Adresse d'expédition — doit appartenir à un domaine vérifié dans Resend.
# À défaut, "onboarding@resend.dev" est utilisé (sandbox, usage limité).
RESEND_FROM_EMAIL=
